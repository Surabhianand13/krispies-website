# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The server will refuse to start if this is left empty or at the default value.
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Admin credentials ─────────────────────────────────────────────────────────
# Password for the admin panel — set this in the backend DB via the setup script
ADMIN_PASSWORD=

# ── Email ─────────────────────────────────────────────────────────────────────
# Your business email — notifications are sent TO this address
ADMIN_EMAIL=your@email.com

# Gmail account that SENDS the notifications
# Use a Gmail App Password (not your regular Gmail password):
#   Gmail → Settings → Security → 2-Step Verification ON → App Passwords → Generate
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
# Change to your actual domain when deploying (e.g. https://krispies.in)
FRONTEND_URL=http://localhost:3737
